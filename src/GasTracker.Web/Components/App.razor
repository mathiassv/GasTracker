<!DOCTYPE html>
<html lang="en" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["GasTracker.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="manifest" href="manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="GasTracker" />
    <meta name="theme-color" content="#1b6ec2" />
    <link rel="apple-touch-icon" href="icons/icon-192.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
    <title>GasTracker</title>
    <!-- Apply theme before first paint to avoid flash -->
    <script>
        (function () {
            var t = localStorage.getItem('gt-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme',
                t === 'system'
                    ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                    : t);
        })();
    </script>
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        // Blazorise.Charts 1.7.x expects Chart.overrides.pie/doughnut.plugins.tooltip.callbacks
        // to be pre-initialized, but Chart.js 4.x leaves them undefined. Shim it here
        // synchronously so the charts.js ES module can safely read it on load.
        ['pie', 'doughnut'].forEach(function (type) {
            var o = Chart.overrides[type];
            o.plugins = o.plugins || {};
            o.plugins.tooltip = o.plugins.tooltip || {};
            o.plugins.tooltip.callbacks = o.plugins.tooltip.callbacks || {};
        });
    </script>
    <script src="theme.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/sw.js');
            });
        }
    </script>
</body>

</html>
