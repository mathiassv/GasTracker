@using Blazorise.Charts
@inject FuelCalculatorService Calc
@inject UnitConversionService Units

<LineChart TItem="decimal" @ref="_chart" />

@code {
    [Parameter] public List<FuelLog> Logs { get; set; } = [];
    [Parameter] public string CostDistUnit { get; set; } = "10km";
    [Parameter] public string CurrencySymbol { get; set; } = "kr";
    [Parameter] public decimal? StartingOdometer { get; set; }

    private LineChart<decimal> _chart = null!;
    private bool _rendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _rendered = true;
            await RenderChartAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_rendered)
            await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        await _chart.Clear();

        var points = BuildDataPoints();
        if (!points.Any()) return;

        var label = $"{CurrencySymbol}/{Units.CostDistLabel(CostDistUnit)}";

        await _chart.AddLabelsDatasetsAndUpdate(
            points.Select(p => p.Label).ToList(),
            new LineChartDataset<decimal>
            {
                Label = label,
                Data = points.Select(p => p.Value).ToList(),
                BackgroundColor = "rgba(40,167,69,0.2)",
                BorderColor = "rgba(40,167,69,1)",
                Fill = true
            });
    }

    private List<(string Label, decimal Value)> BuildDataPoints()
    {
        var result = new List<(string, decimal)>();
        var ordered = Logs.OrderBy(f => f.FilledAt).ToList();

        for (int i = 0; i < ordered.Count; i++)
        {
            if (ordered[i].IsPartialFillUp) continue;
            var stats = Calc.AccumulatedStats(ordered, i, StartingOdometer);
            if (stats is null) continue;

            var cpk = Calc.CostPerKm(stats.Value.TotalCost, stats.Value.DistanceKm);
            if (!cpk.HasValue) continue;
            var value = Units.CostPerDistUnit(cpk.Value, CostDistUnit);
            result.Add((ordered[i].FilledAt.ToLocalTime().ToString("MMM d"), Math.Round(value, 2)));
        }
        return result;
    }
}
