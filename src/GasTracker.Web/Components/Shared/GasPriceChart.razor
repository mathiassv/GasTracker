@using Blazorise.Charts
@inject UnitConversionService Units

<LineChart TItem="decimal" @ref="_chart" />

@code {
    [Parameter] public List<FuelLog> Logs { get; set; } = [];
    [Parameter] public string Unit { get; set; } = "km";
    [Parameter] public string CurrencySymbol { get; set; } = "kr";

    private LineChart<decimal> _chart = null!;
    private bool _rendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { _rendered = true; await RenderChartAsync(); }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_rendered) await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        await _chart.Clear();
        var points = BuildDataPoints();
        if (!points.Any()) return;

        var volUnit = Unit == "miles" ? "gal" : "L";

        await _chart.AddLabelsDatasetsAndUpdate(
            points.Select(p => p.Label).ToList(),
            new LineChartDataset<decimal>
            {
                Label = $"{CurrencySymbol}/{volUnit}",
                Data = points.Select(p => p.Value).ToList(),
                BackgroundColor = "rgba(220,105,0,0.15)",
                BorderColor = "rgba(220,105,0,1)",
                Fill = true
            });
    }

    private List<(string Label, decimal Value)> BuildDataPoints()
    {
        var result = new List<(string, decimal)>();

        foreach (var log in Logs.OrderBy(f => f.FilledAt))
        {
            var volumeDisplay = Units.ConvertVolume(log.LitersFilled, Unit);
            if (volumeDisplay <= 0 || log.TotalCost <= 0) continue;

            var pricePerUnit = log.TotalCost / volumeDisplay;
            result.Add((log.FilledAt.ToLocalTime().ToString("MMM d"), Math.Round(pricePerUnit, 2)));
        }

        return result;
    }
}
