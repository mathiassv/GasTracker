@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IWebHostEnvironment Env
@inject IJSRuntime JS
@inject IUnitOfWork Uow

<div class="gt-app">
    <!-- Top bar -->
    <header class="gt-topbar d-flex align-items-center px-3">
        <span class="gt-logo fw-bold me-auto">
            <i class="fa fa-gas-pump me-2"></i>GasTracker
        </span>
        <button class="gt-theme-toggle me-2" @onclick="ToggleThemeAsync" title="Toggle theme">
            <i class="fa @(_isDark ? "fa-sun" : "fa-moon")"></i>
        </button>
        <AuthorizeView>
            <Authorized>
                <form method="post" action="/auth/logout" class="mb-0">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-sm btn-outline-light">Sign out</button>
                </form>
            </Authorized>
        </AuthorizeView>
    </header>

    <!-- Page content -->
    <main class="gt-content">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="alert alert-danger m-3">
                    <strong>Something went wrong.</strong>
                    @if (Env.IsDevelopment())
                    {
                        <p class="small mb-1">@ex.Message</p>
                    }
                    <button class="btn btn-sm btn-danger" @onclick="() => Nav.NavigateTo(Nav.Uri, true)">Reload</button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <!-- Bottom nav for mobile -->
    <nav class="gt-bottom-nav d-flex justify-content-around align-items-center">
        <AuthorizeView>
            <Authorized>
                <a href="/cars" class="gt-nav-item @IsActive("/cars")">
                    <i class="fa fa-car"></i>
                    <span>Cars</span>
                </a>
                <a href="/stats" class="gt-nav-item @IsActive("/stats")">
                    <i class="fa fa-chart-line"></i>
                    <span>Stats</span>
                </a>
                <a href="/profile" class="gt-nav-item @IsActive("/profile")">
                    <i class="fa fa-user"></i>
                    <span>Profile</span>
                </a>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="gt-nav-item">
                    <i class="fa fa-sign-in-alt"></i>
                    <span>Login</span>
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private bool _isDark;
    private AppUser? _user;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = auth.User.FindFirst("app_user_id")?.Value;

        if (int.TryParse(userIdStr, out var userId))
        {
            _user = await Uow.Users.GetByIdAsync(userId);
            if (_user is not null)
            {
                await JS.InvokeVoidAsync("gtTheme.apply", _user.Theme);
                _isDark = _user.Theme == "dark";
                StateHasChanged();
                return;
            }
        }

        // Not logged in — read from localStorage
        var stored = await JS.InvokeAsync<string>("gtTheme.get");
        _isDark = stored == "dark";
        StateHasChanged();
    }

    private async Task ToggleThemeAsync()
    {
        _isDark = !_isDark;
        var theme = _isDark ? "dark" : "light";
        await JS.InvokeVoidAsync("gtTheme.apply", theme);

        if (_user is not null)
        {
            _user.Theme = theme;
            await Uow.Users.UpdateAsync(_user);
            await Uow.SaveChangesAsync();
        }
    }

    private string IsActive(string prefix) =>
        Nav.Uri.Contains(prefix, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
