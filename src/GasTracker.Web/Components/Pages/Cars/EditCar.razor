@page "/cars/{CarId:int}/edit"
@layout MainLayout
@attribute [Authorize]
@inject IUnitOfWork Uow
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Edit Car — GasTracker</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="/cars/@CarId" class="btn btn-sm btn-outline-secondary me-2"><i class="fa fa-arrow-left"></i></a>
    <h2 class="h4 mb-0">Edit Car</h2>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_car is null)
{
    <div class="alert alert-warning">Car not found.</div>
}
else
{
    <EditForm Model="_model" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label fw-bold">Name <span class="text-danger">*</span></label>
            <InputText class="form-control" @bind-Value="_model.Name" maxlength="100" />
            <ValidationMessage For="() => _model.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">License plate</label>
            <InputText class="form-control" @bind-Value="_model.LicensePlate" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Starting odometer (@_unit)</label>
            <InputNumber class="form-control" @bind-Value="_model.StartingOdometerDisplay" />
            <ValidationMessage For="() => _model.StartingOdometerDisplay" />
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-2" disabled="@_saving">
            @(_saving ? "Saving…" : "Save changes")
        </button>
    </EditForm>
}

@code {
    [Parameter] public int CarId { get; set; }

    private Car? _car;
    private bool _loading = true;
    private bool _saving;
    private string _unit = "km";
    private int _userId;
    private CarFormModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = int.Parse(auth.User.FindFirst("app_user_id")?.Value ?? "0");
        var user = await Uow.Users.GetByIdAsync(_userId);
        _unit = user?.PreferredUnit ?? "km";

        _car = await Uow.Cars.GetByIdAsync(CarId);
        if (_car is null || _car.AppUserId != _userId)
        {
            _car = null;
            _loading = false;
            return;
        }

        var displayOdo = _unit == "miles" ? _car.StartingOdometer / 1.60934m : _car.StartingOdometer;
        _model = new CarFormModel
        {
            Name = _car.Name,
            LicensePlate = _car.LicensePlate,
            StartingOdometerDisplay = Math.Round(displayOdo, 1)
        };
        _loading = false;
    }

    private async Task SubmitAsync()
    {
        if (_car is null) return;
        _saving = true;
        var odoKm = _unit == "miles"
            ? _model.StartingOdometerDisplay * 1.60934m
            : _model.StartingOdometerDisplay;

        _car.Name = _model.Name;
        _car.LicensePlate = string.IsNullOrWhiteSpace(_model.LicensePlate) ? null : _model.LicensePlate;
        _car.StartingOdometer = odoKm;
        await Uow.Cars.UpdateAsync(_car);
        await Uow.SaveChangesAsync();
        Nav.NavigateTo($"/cars/{CarId}");
    }

    private class CarFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string Name { get; set; } = "";
        public string? LicensePlate { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0, double.MaxValue, ErrorMessage = "Must be 0 or greater")]
        public decimal StartingOdometerDisplay { get; set; }
    }
}
