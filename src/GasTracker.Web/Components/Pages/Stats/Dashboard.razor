@page "/stats"
@layout MainLayout
@attribute [Authorize]
@inject IUnitOfWork Uow
@inject AuthenticationStateProvider AuthState
@inject FuelCalculatorService Calc
@inject UnitConversionService Units
@inject DisplayFormatter Fmt

<PageTitle>Stats — GasTracker</PageTitle>

<h2 class="h4 mb-3">Stats</h2>

@if (_loading)
{
    <LoadingSpinner />
}
else if (!_cars.Any())
{
    <div class="text-center text-muted py-4">
        <p>Add a car and some fill-ups to see stats.</p>
        <a href="/cars" class="btn btn-primary">Go to Cars</a>
    </div>
}
else
{
    <div class="mb-3">
        <select class="form-select" @bind="_selectedCarId" @bind:after="LoadLogsAsync">
            @foreach (var car in _cars)
            {
                <option value="@car.Id">@car.Name</option>
            }
        </select>
    </div>

    <div class="btn-group w-100 mb-3" role="group">
        @foreach (var r in _ranges)
        {
            <button class="btn btn-sm @(_selectedRange == r.Days ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SetRange(r.Days)">@r.Label</button>
        }
    </div>

    @if (!_logs.Any())
    {
        <div class="text-muted text-center py-3">No fill-ups in this period.</div>
    }
    else
    {
        <!-- Summary stats -->
        <div class="row g-2 mb-3">
            <div class="col-6">
                <div class="stat-badge">
                    <div class="stat-value">@_avgEfficiency</div>
                    <div class="stat-label">@_efficiencyLabel</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-badge">
                    <div class="stat-value">@_avgCostPerDist</div>
                    <div class="stat-label">@_costLabel</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-badge">
                    <div class="stat-value">@_totalCost</div>
                    <div class="stat-label">total spent</div>
                </div>
            </div>
            <div class="col-6">
                <div class="stat-badge">
                    <div class="stat-value">@_totalDist @_distUnit</div>
                    <div class="stat-label">total distance</div>
                </div>
            </div>
        </div>

        <h6>Fuel Efficiency (@Units.EfficiencyLabel(_costDistUnit))</h6>
        <FuelEfficiencyChart Logs="@_logs" CostDistUnit="@_costDistUnit" />

        <h6 class="mt-3">Cost per @Units.CostDistLabel(_costDistUnit)</h6>
        <CostPerDistanceChart Logs="@_logs" CostDistUnit="@_costDistUnit" CurrencySymbol="@_currencySymbol" />
    }
}

@code {
    private List<Car> _cars = [];
    private List<FuelLog> _logs = [];
    private bool _loading = true;
    private int _userId;
    private string _unit = "km";
    private string _distUnit = "km";
    private int _statScale = 10;
    private string _costDistUnit = "10km";
    private string _currencySymbol = "kr";
    private int _selectedCarId;
    private int _selectedRange = 90;

    private string _avgEfficiency = "—";
    private string _efficiencyLabel = "L/10km";
    private string _avgCostPerDist = "—";
    private string _costLabel = "kr/10 km";
    private string _totalCost = "—";
    private string _totalDist = "—";

    private record RangeOption(string Label, int Days);
    private readonly List<RangeOption> _ranges =
    [
        new("30d", 30),
        new("90d", 90),
        new("1y", 365),
        new("All", 0)
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = int.Parse(auth.User.FindFirst("app_user_id")?.Value ?? "0");
        var user = await Uow.Users.GetByIdAsync(_userId);
        _unit = user?.PreferredUnit ?? "km";
        _distUnit = _unit == "miles" ? "mi" : "km";
        _statScale = user?.StatScale ?? 10;
        _costDistUnit = Units.BuildCostDistUnit(_unit, _statScale);
        _currencySymbol = user?.CurrencySymbol ?? "kr";
        _efficiencyLabel = Units.EfficiencyLabel(_costDistUnit);
        _costLabel = $"{_currencySymbol}/{Units.CostDistLabel(_costDistUnit)}";

        _cars = (await Uow.Cars.GetByUserIdAsync(_userId)).ToList();
        if (_cars.Any())
        {
            _selectedCarId = _cars[0].Id;
            await LoadLogsAsync();
        }
        _loading = false;
    }

    private async Task LoadLogsAsync()
    {
        if (_selectedCarId == 0) return;

        IEnumerable<FuelLog> raw;
        if (_selectedRange == 0)
        {
            raw = await Uow.FuelLogs.GetByCarIdAsync(_selectedCarId, _userId);
        }
        else
        {
            var from = DateTime.UtcNow.AddDays(-_selectedRange);
            raw = await Uow.FuelLogs.GetByCarIdInRangeAsync(_selectedCarId, _userId, from, DateTime.UtcNow);
        }
        _logs = raw.OrderBy(f => f.FilledAt).ToList();
        ComputeSummary();
    }

    private void SetRange(int days)
    {
        _selectedRange = days;
        _ = LoadLogsAsync();
    }

    private void ComputeSummary()
    {
        var efficiencies = new List<decimal>();
        var costPerDists = new List<decimal>();

        for (int i = 1; i < _logs.Count; i++)
        {
            var curr = _logs[i];
            var prev = _logs[i - 1];
            var distKm = curr.OdometerReading - prev.OdometerReading;
            if (distKm <= 0) continue;

            // Efficiency
            var eff = Units.LitersPerDistUnit(curr.LitersFilled, distKm, _costDistUnit)
                ?? Calc.MilesPerGallon(Units.KmToMiles(distKm), Units.LitersToGallons(curr.LitersFilled));
            if (eff.HasValue) efficiencies.Add(eff.Value);

            // Cost per configured distance unit
            var cpk = Calc.CostPerKm(curr.TotalCost, distKm);
            if (cpk.HasValue) costPerDists.Add(Units.CostPerDistUnit(cpk.Value, _costDistUnit));
        }

        _avgEfficiency = efficiencies.Any()
            ? Fmt.Num(efficiencies.Average(), 1)
            : "—";
        _avgCostPerDist = costPerDists.Any()
            ? Fmt.Currency(costPerDists.Average(), _currencySymbol)
            : "—";

        var totalCostVal = _logs.Sum(l => l.TotalCost);
        _totalCost = Fmt.Currency(totalCostVal, _currencySymbol);

        if (_logs.Count >= 2)
        {
            var distKmTotal = _logs.Last().OdometerReading - _logs.First().OdometerReading;
            var distDisplay = _unit == "miles" ? Units.KmToMiles(distKmTotal) : distKmTotal;
            _totalDist = Fmt.Num(distDisplay, 0);
        }
        else
        {
            _totalDist = "—";
        }
    }
}
