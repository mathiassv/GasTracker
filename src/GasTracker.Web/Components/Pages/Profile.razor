@page "/profile"
@layout MainLayout
@attribute [Authorize]
@inject IUnitOfWork Uow
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>Profile — GasTracker</PageTitle>

<h2 class="h4 mb-3">Profile</h2>

@if (_user is null)
{
    <LoadingSpinner />
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label fw-bold">Name</label>
            <input class="form-control" value="@_user.DisplayName" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Email</label>
            <input class="form-control" value="@_user.Email" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Preferred unit</label>
            <select class="form-select" @bind="_model.PreferredUnit">
                <option value="km">km / liters (metric)</option>
                <option value="miles">miles / gallons (imperial)</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Stats scale</label>
            <select class="form-select" @bind="_model.StatScale">
                <option value="1">Per 1 unit (km or mi)</option>
                <option value="10">Per 10 units (default)</option>
                <option value="100">Per 100 units</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Theme</label>
            <select class="form-select" @bind="_model.Theme">
                <option value="light">Light</option>
                <option value="dark">Dark</option>
                <option value="system">System default</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Currency code</label>
            <InputText class="form-control" @bind-Value="_model.CurrencyCode" maxlength="3" placeholder="SEK" />
            <ValidationMessage For="() => _model.CurrencyCode" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Currency symbol</label>
            <InputText class="form-control" @bind-Value="_model.CurrencySymbol" maxlength="5" placeholder="kr" />
            <ValidationMessage For="() => _model.CurrencySymbol" />
        </div>

        <button type="submit" class="btn btn-primary w-100" disabled="@_saving">
            @(_saving ? "Saving…" : "Save")
        </button>

        @if (_saved)
        {
            <div class="alert alert-success mt-3">Saved!</div>
        }
    </EditForm>

    <hr class="my-4" />

    <h5 class="mb-3">Data</h5>

    <div class="mb-3">
        <p class="text-muted small">Export all your cars and fill-up history as a JSON file.</p>
        <button class="btn btn-outline-primary w-100" @onclick="ExportAsync" disabled="@_exporting">
            <i class="fa fa-download me-2"></i>@(_exporting ? "Exporting…" : "Export to JSON")
        </button>
    </div>

    <div class="mb-3">
        <p class="text-muted small">
            Import cars and fill-ups from a previously exported JSON file.
            Imported cars are always added as new entries.
        </p>
        <InputFile class="form-control mb-2" OnChange="OnFileSelected" accept=".json" />
        @if (_importFile is not null)
        {
            <div class="form-text mb-2">Selected: @_importFile.Name (@FormatBytes(_importFile.Size))</div>
        }
        <button class="btn btn-outline-secondary w-100" @onclick="ImportAsync"
                disabled="@(_importFile is null || _importing)">
            <i class="fa fa-upload me-2"></i>@(_importing ? "Importing…" : "Import from JSON")
        </button>
        @if (_importResult is not null)
        {
            <div class="alert @(_importError ? "alert-danger" : "alert-success") mt-2">@_importResult</div>
        }
    </div>
}

@code {
    private AppUser? _user;
    private ProfileModel _model = new();
    private bool _saving;
    private bool _saved;
    private bool _exporting;
    private bool _importing;
    private IBrowserFile? _importFile;
    private string? _importResult;
    private bool _importError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = int.Parse(auth.User.FindFirst("app_user_id")?.Value ?? "0");
        _user = await Uow.Users.GetByIdAsync(userId);
        if (_user is not null)
        {
            _model = new ProfileModel
            {
                PreferredUnit = _user.PreferredUnit,
                StatScale = _user.StatScale,
                CurrencyCode = _user.CurrencyCode,
                CurrencySymbol = _user.CurrencySymbol,
                Theme = _user.Theme
            };
        }
    }

    private async Task SaveAsync()
    {
        if (_user is null) return;
        _saving = true;
        _saved = false;
        _user.PreferredUnit = _model.PreferredUnit;
        _user.StatScale = _model.StatScale;
        _user.CurrencyCode = _model.CurrencyCode.ToUpper();
        _user.CurrencySymbol = _model.CurrencySymbol;
        _user.Theme = _model.Theme;
        await Uow.Users.UpdateAsync(_user);
        await Uow.SaveChangesAsync();
        await JS.InvokeVoidAsync("gtTheme.apply", _user.Theme);
        _saving = false;
        _saved = true;
    }

    // ── Export ──────────────────────────────────────────────────────────────

    private async Task ExportAsync()
    {
        if (_user is null) return;
        _exporting = true;

        var cars = await Uow.Cars.GetByUserIdAsync(_user.Id);
        var carDtos = new List<CarExportDto>();

        foreach (var car in cars)
        {
            var logs = await Uow.FuelLogs.GetByCarIdAsync(car.Id, _user.Id);
            carDtos.Add(new CarExportDto(
                car.Name,
                car.LicensePlate,
                car.StartingOdometer,
                car.CreatedAt,
                logs.OrderBy(l => l.FilledAt).Select(l => new FuelLogExportDto(
                    l.OdometerReading,
                    l.LitersFilled,
                    l.TotalCost,
                    l.FilledAt,
                    l.IsPartialFillUp,
                    l.Notes
                )).ToList()
            ));
        }

        var export = new ExportDto(DateTime.UtcNow, 1, carDtos);
        var json = JsonSerializer.Serialize(export, JsonOptions);
        var filename = $"gastracker-export-{DateTime.UtcNow:yyyy-MM-dd}.json";
        await JS.InvokeVoidAsync("gtApp.downloadJson", filename, json);

        _exporting = false;
    }

    // ── Import ──────────────────────────────────────────────────────────────

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _importFile = e.File;
        _importResult = null;
        _importError = false;
    }

    private async Task ImportAsync()
    {
        if (_user is null || _importFile is null) return;
        _importing = true;
        _importResult = null;
        _importError = false;

        try
        {
            const int maxBytes = 10 * 1024 * 1024; // 10 MB
            await using var stream = _importFile.OpenReadStream(maxBytes);
            var export = await JsonSerializer.DeserializeAsync<ExportDto>(stream, JsonOptions);

            if (export is null || export.Version != 1)
            {
                _importResult = "Invalid or unsupported file format.";
                _importError = true;
                return;
            }

            int carsAdded = 0, logsAdded = 0;

            foreach (var carDto in export.Cars)
            {
                var car = new Car
                {
                    AppUserId = _user.Id,
                    Name = carDto.Name,
                    LicensePlate = carDto.LicensePlate,
                    StartingOdometer = carDto.StartingOdometer,
                    CreatedAt = carDto.CreatedAt
                };
                await Uow.Cars.AddAsync(car);
                await Uow.SaveChangesAsync(); // flush to get car.Id

                foreach (var logDto in carDto.FuelLogs)
                {
                    await Uow.FuelLogs.AddAsync(new FuelLog
                    {
                        CarId = car.Id,
                        OdometerReading = logDto.OdometerReading,
                        LitersFilled = logDto.LitersFilled,
                        TotalCost = logDto.TotalCost,
                        FilledAt = logDto.FilledAt,
                        IsPartialFillUp = logDto.IsPartialFillUp,
                        Notes = logDto.Notes
                    });
                    logsAdded++;
                }

                await Uow.SaveChangesAsync();
                carsAdded++;
            }

            _importResult = $"Imported {carsAdded} car{(carsAdded != 1 ? "s" : "")} and {logsAdded} fill-up{(logsAdded != 1 ? "s" : "")}.";
            _importFile = null;
        }
        catch (JsonException)
        {
            _importResult = "Could not parse the file. Make sure it is a valid GasTracker export.";
            _importError = true;
        }
        catch (Exception ex)
        {
            _importResult = $"Import failed: {ex.Message}";
            _importError = true;
        }
        finally
        {
            _importing = false;
        }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024} KB",
        _ => $"{bytes / (1024 * 1024)} MB"
    };

    // ── JSON options ─────────────────────────────────────────────────────────

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        Converters = { new JsonStringEnumConverter() }
    };

    // ── DTOs ─────────────────────────────────────────────────────────────────

    private record ExportDto(
        DateTime ExportedAt,
        int Version,
        List<CarExportDto> Cars);

    private record CarExportDto(
        string Name,
        string? LicensePlate,
        decimal StartingOdometer,
        DateTime CreatedAt,
        List<FuelLogExportDto> FuelLogs);

    private record FuelLogExportDto(
        decimal OdometerReading,
        decimal LitersFilled,
        decimal TotalCost,
        DateTime FilledAt,
        bool IsPartialFillUp,
        string? Notes);

    // ── Profile form model ────────────────────────────────────────────────────

    private class ProfileModel
    {
        public string PreferredUnit { get; set; } = "km";
        public int StatScale { get; set; } = 10;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Currency code is required")]
        [System.ComponentModel.DataAnnotations.StringLength(3, MinimumLength = 3, ErrorMessage = "Must be exactly 3 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[A-Za-z]{3}$", ErrorMessage = "Must be 3 letters (e.g. USD, SEK)")]
        public string CurrencyCode { get; set; } = "SEK";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Currency symbol is required")]
        [System.ComponentModel.DataAnnotations.StringLength(5, MinimumLength = 1, ErrorMessage = "Required")]
        public string CurrencySymbol { get; set; } = "kr";

        public string Theme { get; set; } = "light";
    }
}
